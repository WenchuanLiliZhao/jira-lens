{
  "extends": [
    "development"
  ],
  "hints": {
    "disown-opener": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "user-select",
          "scrollbar-width",
          "scrollbar-width: none",
          "backdrop-filter"
        ]
      }
    ],
    "no-inline-styles": "off",
    "axe/forms": [
      "default",
      {
        "select-name": "off"
      }
    ],
    "axe/aria": [
      "default",
      {
        "aria-roles": "off",
        "aria-valid-attr-value": "off"
      }
    ],
    "typescript-config/is-valid": "off",
    "typescript-config/consistent-casing": "off"
  }
}