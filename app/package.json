{
  "name": "jira-lens",
  "displayName": "Jira Lens",
  "description": "A Notion-inspired Jira observation layer for VS Code and Cursor",
  "publisher": "WenchuanLiliZhao",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:jira-lens.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jira-lens.open",
        "title": "Open Jira Lens"
      }
    ],
    "configuration": {
      "title": "Jira Lens",
      "properties": {
        "jira-lens.domain": {
          "type": "string",
          "default": "",
          "description": "Jira site domain (e.g. your-company.atlassian.net)"
        },
        "jira-lens.email": {
          "type": "string",
          "default": "",
          "description": "Atlassian account email used for API authentication"
        }
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:jira-proxy": "node src/jira-lens/server.js",
    "dev:jira": "concurrently -n proxy,ui -c blue,green \"npm run dev:jira-proxy\" \"npm run dev\"",
    "build": "npm run build:webview && npm run build:extension && npm run build:mcp",
    "build:webview": "tsc -b && vite build",
    "build:extension": "tsc -p tsconfig.extension.json && node -e \"require('fs').writeFileSync('out/package.json', JSON.stringify({type:'commonjs'}))\"",
    "build:mcp": "node scripts/build-mcp.cjs",
    "query": "node out/mcp/cli/query.js",
    "query:done": "node out/mcp/cli/query.js --status Done",
    "query:todo": "node out/mcp/cli/query.js --status 'To Do'",
    "query:inprogress": "node out/mcp/cli/query.js --status 'In Progress'",
    "query:all": "node out/mcp/cli/query.js --status all",
    "bulk:move": "node out/mcp/cli/bulk-move.js",
    "bulk:assign": "node out/mcp/cli/bulk-assign.js",
    "bulk:transition": "node out/mcp/cli/bulk-transition.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "vsce:package": "vsce package",
    "move": "python3 ../scripts/component/move/move_component.py",
    "figma-colors": "python3 ../scripts/map_figma_tokens_to_scss.py",
    "update-demo-indexes": "python3 ../scripts/regenerate_demo_indexes.py",
    "update-pages": "npm run update-demo-indexes && python3 ../scripts/update_index_files.py",
    "publish-base-table": "python3 ../scripts/publish_base_table.py"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "maplibre-gl": "^4.7.1",
    "marked": "^17.0.4",
    "md-to-adf": "^0.6.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "sass": "^1.97.2",
    "swiper": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/maplibre-gl": "^1.14.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/vsce": "^3.7.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.5"
  }
}
