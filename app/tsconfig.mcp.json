{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "outDir": "out/mcp",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["src/mcp/server.ts", "src/cli/**/*.ts", "src/lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
